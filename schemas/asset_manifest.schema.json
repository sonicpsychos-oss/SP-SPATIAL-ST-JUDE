{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StJudeSpatialAssetManifest",
  "type": "object",
  "required": [
    "version",
    "assets"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "lod",
          "source",
          "texture_atlas",
          "physical_properties"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "lod": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "texture_atlas": {
            "type": "string",
            "enum": [
              "2k"
            ]
          },
          "physical_properties": {
            "type": "object",
            "required": [
              "material",
              "acoustic_absorption",
              "reverb_profile"
            ],
            "properties": {
              "material": {
                "type": "string"
              },
              "acoustic_absorption": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "reverb_profile": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
